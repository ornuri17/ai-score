# Copy to terraform.tfvars and fill in values. terraform.tfvars is gitignored.

aws_region   = "us-east-1"
environment  = "prod"
domain_name  = "gradebyai.com"
alert_email  = "you@example.com"

# Sensitive — never commit these
db_password      = "change-me-strong-password"
sendgrid_api_key = "SG.xxxxxxxxxxxx"

# Optional — leave empty to use CloudFront default domain (*.cloudfront.net)
# To use gradebyai.com, create an ACM cert in us-east-1 first, then paste ARN here
acm_certificate_arn = ""
